{
  "name": "@home-assistant-matter-bridge/root",
  "version": "2026.4.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "cleanup": "pnpm -r run cleanup && pnpm run cleanup:root",
    "cleanup:root": "npx rimraf node_modules",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "pretest": "pnpm run build:minimum",
    "test": "pnpm -r run test",
    "test:coverage": "pnpm -r run test:coverage",
    "build": "pnpm -r run build",
    "build:minimum": "pnpm --filter @home-assistant-matter-bridge/common run build",
    "build:app": "pnpm --filter './packages/*' run build",
    "preserve": "pnpm run build:minimum",
    "serve": "pnpm -r --parallel run serve",
    "start": "pnpm run serve",
    "preproduction": "pnpm run build:app",
    "production": "pnpm --filter home-assistant-matter-bridge run start",
    "check-updates": "npx npm-check-updates --workspaces --root -u"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "docs"
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@dotenvx/dotenvx": "^1.71.0",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.40",
    "@swc/helpers": "~0.5.23",
    "esbuild": "^0.28.0",
    "esbuild-plugin-noexternal": "^0.1.6",
    "globals": "^17.6.0",
    "nodemon": "^3.1.14",
    "npm-check-updates": "^22.2.2",
    "rimraf": "^6.1.3",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
