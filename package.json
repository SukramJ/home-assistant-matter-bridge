{
  "name": "@home-assistant-matter-bridge/root",
  "version": "2026.3.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.1",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "cleanup": "pnpm -r run cleanup && pnpm run cleanup:root",
    "cleanup:root": "npx rimraf node_modules",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "pretest": "pnpm run build:minimum",
    "test": "pnpm -r run test",
    "test:coverage": "pnpm -r run test:coverage",
    "build": "pnpm -r run build",
    "build:minimum": "pnpm --filter @home-assistant-matter-bridge/common run build",
    "build:app": "pnpm --filter './packages/*' run build",
    "preserve": "pnpm run build:minimum",
    "serve": "pnpm -r --parallel run serve",
    "start": "pnpm run serve",
    "preproduction": "pnpm run build:app",
    "production": "pnpm --filter home-assistant-matter-bridge run start",
    "check-updates": "npx npm-check-updates --workspaces --root -u"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "docs"
  ],
  "pnpm": {
    "overrides": {
      "ajv": ">=8.18.0",
      "qs": ">=6.14.2",
      "js-yaml": ">=4.1.1",
      "mdast-util-to-hast": ">=13.2.1",
      "undici": ">=7.24.0",
      "@isaacs/brace-expansion": ">=5.0.1",
      "minimatch": ">=10.2.3",
      "rollup": ">=4.59.0",
      "markdown-it": ">=14.1.1",
      "@codemirror/view": "6.39.15",
      "path-to-regexp": ">=8.4.0",
      "brace-expansion": ">=5.0.5",
      "yaml": ">=2.8.3"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@dotenvx/dotenvx": "^1.59.1",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.21",
    "@swc/helpers": "~0.5.20",
    "esbuild": "^0.27.5",
    "esbuild-plugin-noexternal": "^0.1.6",
    "globals": "^17.4.0",
    "nodemon": "^3.1.14",
    "npm-check-updates": "^20.0.0",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.5",
    "vitest": "^4.1.2"
  }
}
